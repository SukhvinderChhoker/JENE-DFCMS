# ============================================
# JENE-DFCMS Production Deployment
# ============================================
# Copy this to .env and fill in all values
# Then run: docker-compose up -d --build
# ============================================

# --- Database ---
DB_NAME=jene_dfcms
DB_USERNAME=jene_dfcms
DB_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD_123!
DB_PORT_EXTERNAL=5432

# --- JWT ---
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_64_CHAR_STRING_NOW
JWT_EXPIRATION=3600000

# --- Application ---
CORS_ORIGIN=http://your-domain.com
SPRING_PROFILES_ACTIVE=prod

# --- Ports ---
BACKEND_PORT=8080
FRONTEND_PORT=80

# --- License ---
LICENSE_FILE=license/jene-dfcms.license
LICENSE_REQUIRED=true

# --- Docker Image (for push to registry) ---
DOCKER_REGISTRY=your-dockerhub-username
IMAGE_NAME=jene-dfcms
IMAGE_TAG=1.0.0
