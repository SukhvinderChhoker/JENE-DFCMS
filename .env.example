# ============================================
# JENE-DFCMS Environment Configuration
# Copy this to .env and modify for your environment
# ============================================

# Database
DB_NAME=jene_dfcms
DB_USERNAME=jene_dfcms
DB_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD
DB_PORT_EXTERNAL=5432

# JWT (CHANGE THIS to a random 64+ char string)
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_SECRET_KEY_AT_LEAST_32_CHARS_LONG
JWT_EXPIRATION=3600000

# Ports
BACKEND_PORT=8080
FRONTEND_PORT=80
